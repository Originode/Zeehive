# ZEEHIVE queenzee — containerized orchestrator. EXPERIMENTAL (compose profile: experimental):
# building this image works today; RUNNING it as the live queenzee waits on the repo migration
# below. The blocker is not the process, it is the FILES: the queenzee's job is cutting git
# worktrees that agent sessions work in, and a worktree's .git file stores an absolute gitdir
# path that only resolves on the side that wrote it. A Linux queenzee minting /repos/... paths
# strands every Windows-host session (and the meta-DB is full of D:/ paths from the host era).
#
# The sanctioned migration (agreed 2026-07-18): move the PROJECT FOLDERS to the Linux side —
# repos live on a named volume (or a WSL distro's ext4), this container and its headless zees
# (in-container `claude` CLI) do all git natively there, and Windows visits via
# \\wsl.localhost\... / VS Code Remote instead of owning the files. Until that lands, the live
# queenzee stays a host process (the self-ship pattern) and this image is the runway.
#
# What the runtime needs, and why:
#   git + bash        — every provisioning/land/reap/build script
#   docker CLI        — drives the fleet daemons (mounted socket for local, TCP contexts beyond)
#   claude CLI        — spawns headless zees as child processes (auth: mount a logged-in
#                       ~/.claude or pass ANTHROPIC_API_KEY; see compose)
FROM node:22-bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends \
      git bash ca-certificates curl openssh-client \
    && rm -rf /var/lib/apt/lists/*
# docker CLI only (no daemon) — the static binary from the official CLI image
COPY --from=docker:cli /usr/local/bin/docker /usr/local/bin/docker
RUN npm install -g @anthropic-ai/claude-code

WORKDIR /app
COPY package.json package-lock.json ./
COPY server/package.json server/
RUN npm ci --workspace server
COPY server/ server/
COPY scripts/ scripts/
COPY db/ db/
COPY hooks/ hooks/
COPY skill/ skill/

ENV NODE_NO_WARNINGS=1
EXPOSE 4700
CMD ["node", "server/src/index.js"]
