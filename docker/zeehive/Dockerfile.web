# ZEEHIVE production dashboard — the REAL prod artifact: the built bundle behind nginx, not a
# vite dev server that happens to be running. /api (including the SSE stream) proxies to the
# queenzee API on the host — see nginx-web.conf.
#
# Build context is the REPO ROOT (see docker-compose.prod.yml): the web workspace needs the root
# package-lock for a reproducible install.
FROM node:22-alpine AS build
WORKDIR /src
COPY package.json package-lock.json ./
COPY web/package.json web/
RUN npm ci --workspace web
COPY web/ web/
RUN npm --workspace web run build

FROM nginx:alpine
COPY docker/zeehive/nginx-web.conf /etc/nginx/conf.d/default.conf
COPY --from=build /src/web/dist /usr/share/nginx/html
EXPOSE 5180
