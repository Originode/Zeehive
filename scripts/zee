#!/usr/bin/env node
// `zee` — the CXELLD zee's in-cxell CLI. A cxell zee has no docker, no host fs and no skills; the
// queenzee API is its only door out of the cxell. This wraps the /api/xell/self/* verbs so the zee
// (or an attending human in the cxell's SSH shell) doesn't hand-roll curl.
//
//   zee status [--wait]
//   zee build [server|webapp|all] [--hot] [--wait[=secs]] [--watch]
//   zee working [--note "what you are doing"]
//   zee tend --reason "why you need a human"   |   zee tend --clear
//   zee land [--wait]
//   zee ship [--targets server webapp] --reason "what you are shipping"
//   zee prod --reason "why you need the prod database"
//   zee done --summary "what you finished"
//
// --wait (on `land` and `status`) BLOCKS, polling until the landing is decided (landed/rejected/
// stale), and exits with that verdict — its exit is your nudge, so run it in the BACKGROUND. The
// queenzee ALSO nudges a cxell zee on approval (it resumes your session); --wait is the backup.
//
// Auth is $ZEEHIVE_XELL_TOKEN (injected into the cxell env at spawn). The queenzee is reached at
// host.docker.internal:4700 by default (already firewall-allowed); override with $ZEEHIVE_API.
//
// `zee land`/`zee ship`/`zee prod`/`zee done` are each only a REQUEST that lands on a HUMAN gate —
// they do not act unilaterally; a human approves in the ZEEHIVE console, then the queenzee does the
// work. `zee build` is the ONE exception: it acts immediately, because building your OWN throwaway
// app-tier containers (to run e2e tests against your change) needs no human. It collects your cxell
// COMMITS onto the worktree first, then runs the same queenzee build a host-side zee runs, so the
// built commit/hot flag/health all stay truthful — COMMIT before you build.
import http from 'node:http';
import https from 'node:https';

const api = process.env.ZEEHIVE_API || 'http://host.docker.internal:4700';
const token = process.env.ZEEHIVE_XELL_TOKEN || '';
const [cmd, ...rest] = process.argv.slice(2);

function flag(name) { const i = rest.indexOf(`--${name}`); return i >= 0 ? rest[i + 1] : null; }
// --wait is a boolean flag with an optional =<secs> (default 1h). `--wait 30` is NOT supported —
// the value form is `--wait=30`, so a bare `--wait` never eats the next positional.
function waitFlag() {
  const eq = rest.find((a) => a.startsWith('--wait='));
  if (eq) return { on: true, secs: Number(eq.split('=')[1]) || 3600 };
  return { on: rest.includes('--wait'), secs: 3600 };
}
const sleep = (ms) => new Promise((r) => setTimeout(r, ms));

// Poll self/status until the landing is decided. Exit is the caller's nudge: landed=0, rejected/
// stale/timeout=1. 'approved' just keeps waiting — the queenzee lands an approval itself now.
async function pollLanding(secs) {
  const deadline = Date.now() + secs * 1000;
  let last = '';
  console.error(`\n  Waiting up to ${secs}s for a human to decide. The queenzee will ALSO nudge you on`);
  console.error(`  approval (it resumes your session); this --wait is the backup signal.\n`);
  while (Date.now() < deadline) {
    await sleep(4000);
    let land;
    try { land = (await req('GET', '/api/xell/self/status')).json?.landing; }
    catch (e) { console.error(`  (status unreadable: ${e.message}) — retrying`); continue; }
    if (!land) { console.error('  … no landing on record yet'); continue; }
    if (land.status !== last) { console.error(`  … ${land.status || 'unknown'}`); last = land.status; }
    if (land.status === 'landed') { console.error(`\n  ✓ LANDED on main${land.new_sha ? ` @ ${String(land.new_sha).slice(0, 8)}` : ''}.\n`); process.exit(0); }
    if (land.status === 'rejected') { console.error('\n  ✗ REJECTED by a human — re-pushing this sha will not help; talk to them.\n'); process.exit(1); }
    if (land.status === 'stale') { console.error('\n  ✗ STALE — main moved past this sha; make a fresh commit and `zee land` again.\n'); process.exit(1); }
    // 'pending' / 'approved' → keep waiting (an approval lands automatically).
  }
  console.error(`\n  ✗ TIMEOUT after ${secs}s — still waiting on a human. Your work is safe on your branch.\n`);
  process.exit(1);
}
// Poll self/build/status until no targeted container is 'building', then report whether each is UP
// and serving THIS cxell's HEAD. Bounded — a wait that can hang forever is the very thing it replaces
// (a zee's curl|grep loop against its own app). Exit 0 = built and serving your HEAD, 1 = failed /
// not-your-code / timeout. Run it in the BACKGROUND: its exit is your nudge. Prints to stderr so a
// backgrounded --wait doesn't tangle with the JSON the build POST already printed to stdout.
async function pollBuild(role, secs, { watch = false } = {}) {
  const deadline = Date.now() + secs * 1000;
  let last = '';
  let first = true;
  while (Date.now() < deadline) {
    // --watch answers "is my code live?" immediately; a wait-after-build needs a beat first.
    if (!first || !watch) await sleep(3000);
    first = false;
    let st;
    try { st = (await req('GET', '/api/xell/self/build/status')).json; }
    catch (e) { console.error(`  (status unreadable: ${e.message}) — retrying`); continue; }
    if (!Array.isArray(st?.containers)) {
      console.error(`\n  ✗ Cannot read build status: ${st?.error || 'unexpected response'}`); process.exit(1);
    }
    const want = role === 'all' ? st.containers : st.containers.filter((c) => c.role === role);
    if (!want.length) { console.error(`\n  ✗ This xell has no ${role} container to build.`); process.exit(1); }
    const line = want.map((c) => `${c.role}=${c.health}`).join(' ');
    if (line !== last) { console.error(`  … ${line}`); last = line; }
    if (want.some((c) => c.health === 'building')) continue;

    // Settled. Report per container, and be explicit about WHY one isn't serving HEAD — "not your
    // code" with no reason is what sends a zee hunting for a phantom bug.
    console.error('');
    let ok = true;
    for (const c of want) {
      if (c.health === 'up' && c.serving_head) {
        console.error(`  ✓ ${c.role} (${c.name}) is UP and serving your HEAD ${String(st.head).slice(0, 8)}`);
      } else if (c.health === 'up' && c.hot_build) {
        console.error(`  ⚠ ${c.role} (${c.name}) is UP but was a --hot bounce: it re-used the old image and is NOT running your code. Rebuild without --hot.`); ok = false;
      } else if (c.health === 'up' && c.never_built) {
        console.error(`  ⚠ ${c.role} (${c.name}) is UP but the queenzee has never built it, so what it serves is unknown — run \`zee build\`.`); ok = false;
      } else if (c.health === 'up') {
        console.error(`  ⚠ ${c.role} (${c.name}) is UP but built at ${String(c.last_build_commit).slice(0, 8)}, not your HEAD ${String(st.head).slice(0, 8)} — your newest commit is not in it. Rebuild.`); ok = false;
      } else {
        console.error(`  ✗ ${c.role} (${c.name}) is ${String(c.health).toUpperCase()} — the build FAILED. Check the queenzee terminal (▚_) on the dashboard.`); ok = false;
      }
    }
    process.exit(ok ? 0 : 1);
  }
  console.error(`\n  ✗ TIMEOUT after ${secs}s — still building. Something is wrong; check the dashboard.`);
  process.exit(1);
}
// --targets takes one-or-more values until the next --flag (or end)
function multi(name) {
  const i = rest.indexOf(`--${name}`);
  if (i < 0) return null;
  const out = [];
  for (let j = i + 1; j < rest.length && !rest[j].startsWith('--'); j++) out.push(rest[j]);
  return out.length ? out : null;
}

function req(method, path, body) {
  return new Promise((resolve, reject) => {
    const data = body ? JSON.stringify(body) : null;
    const lib = api.startsWith('https') ? https : http;
    const r = lib.request(`${api}${path}`, {
      method,
      headers: {
        ...(token ? { authorization: `Bearer ${token}` } : {}),
        ...(data ? { 'content-type': 'application/json', 'content-length': Buffer.byteLength(data) } : {}),
      },
    }, (res) => {
      let b = ''; res.on('data', (c) => (b += c));
      res.on('end', () => { let j; try { j = JSON.parse(b || '{}'); } catch { j = { raw: b }; } resolve({ code: res.statusCode, json: j }); });
    });
    r.on('error', reject);
    if (data) r.write(data);
    r.end();
  });
}

function out(r) {
  console.log(JSON.stringify(r.json, null, 2));
  process.exit(r.code >= 400 ? 1 : 0);
}

function usage() {
  console.log(`zee — cxell-zee ↔ queenzee verbs (each is a REQUEST that lands on a human gate)

  zee status [--wait]                where you stand (hive status + task + pending land/ship/prod/done); --wait blocks until a landing is decided
  zee build [server|webapp|all] [--hot] [--wait[=secs]] [--watch]   (re)build your OWN app tier to run e2e tests (NOT gated; acts now). --wait blocks until it serves your HEAD (run in background); --watch reports without building; --hot bounces the old image (no code change)
  zee device [--detach|--status]      attach a MOBILE DEVICE (Android) to build/install/run your app on (NOT gated; throwaway). Returns the adb address + build→install→launch→screenshot loop; --status shows the current one; --detach gives it back
  zee working [--note "..."]          ping that you are actively working (hive shows occ-working); clears any open tend. NOT gated
  zee tend --reason "..." | --clear   flag that you NEED A HUMAN in the console (hive shows occ-tendRequest); opens no gate, blocks nothing. --clear lowers it
  zee land [--wait]                  collect + catch up + gated push to main (HELD for a human); --wait blocks until decided (run in background)
  zee ship [--targets server webapp] --reason "..."   ask to deploy to prod (must be landed first)
  zee hint-land [--reason "..."] | --clear   flag "this looks land-ready" — lights the land? button for a human WITHOUT landing. Use when NOT 100% certain the job is done
  zee hint-ship [--reason "..."] | --clear   flag "this looks ship-ready" — lights the ship? button for a human WITHOUT shipping. Use when NOT 100% certain the job is done
  zee prod --reason "..."            ASK to be bound to the prod database (a human confirms)
  zee done --summary "..."           propose done (a human confirms with "Mark done")

env: ZEEHIVE_XELL_TOKEN (identity, injected at spawn), ZEEHIVE_API (default host.docker.internal:4700)`);
  process.exit(cmd ? 1 : 0);
}

if (!token && cmd && cmd !== 'help') {
  console.error('no ZEEHIVE_XELL_TOKEN in the environment — this shell is not an authenticated cxell.');
  process.exit(1);
}

switch (cmd) {
  case 'status': {
    const r = await req('GET', '/api/xell/self/status');
    console.log(JSON.stringify(r.json, null, 2));
    const w = waitFlag();
    if (!w.on) process.exit(r.code >= 400 ? 1 : 0);
    const land = r.json?.landing;
    // Nothing pending to wait on → answer now (landed=0, decided-otherwise=1, no landing=0).
    if (!land || !['pending', 'approved'].includes(land.status)) {
      process.exit(land && land.status !== 'landed' ? (['rejected', 'stale'].includes(land.status) ? 1 : 0) : 0);
    }
    await pollLanding(w.secs); // exits
    break;
  }
  case 'land': {
    const r = await req('POST', '/api/xell/self/land', {});
    console.log(JSON.stringify(r.json, null, 2));
    const w = waitFlag();
    const status = r.json?.status;
    if (r.code >= 400 || status === 'needs-resolution' || status === 'error') process.exit(1);
    if (status === 'landed') process.exit(0);
    if (!w.on) process.exit(0); // held, but not asked to wait — the queenzee will nudge on approval
    if (status === 'held') { await pollLanding(w.secs); } // exits
    process.exit(0);
    break;
  }
  case 'build': {
    const role = rest.find((a) => ['server', 'webapp', 'all'].includes(a)) || 'all';
    const hot = rest.includes('--hot');
    const watch = rest.includes('--watch');
    const w = waitFlag();
    const secs = w.secs || 1200;
    // --watch: report only, start nothing (read-only "is what's running actually my code?").
    if (watch) {
      console.error(`Watching ${role} for this cxell (no build started)…`);
      await pollBuild(role, secs, { watch: true }); // exits
      break;
    }
    const r = await req('POST', '/api/xell/self/build', { role, hot });
    console.log(JSON.stringify(r.json, null, 2));
    if (r.code >= 400 || r.json?.ok === false) process.exit(1);
    if (w.on) {
      console.error(`\nWaiting up to ${secs}s for the build to settle (asking the queenzee, not guessing)…`);
      await pollBuild(role, secs, { watch: false }); // exits
    }
    process.exit(0);
    break;
  }
  case 'working': {
    // Ping "I am actively working" — asserts live activity the passive poller can't see for a cxell,
    // and clears any open tend. NOT gated; acts immediately.
    out(await req('POST', '/api/xell/self/working', { note: flag('note') || null }));
    break;
  }
  case 'device': {
    // Attach / --detach / --status a MOBILE DEVICE (Android) to build+install+run your app on. NOT
    // gated (throwaway target, like `zee build`). Attach returns the adb address + the loop.
    const action = rest.includes('--detach') ? 'detach' : rest.includes('--status') ? 'status' : 'attach';
    out(await req('POST', '/api/xell/self/device', { action, kind: flag('kind') || null }));
    break;
  }
  case 'tend': {
    // Flag (or --clear) "I need a human in the console". Opens no gate and blocks nothing.
    const clear = rest.includes('--clear');
    const reason = flag('reason');
    if (!clear && !reason) { console.error('tend needs --reason "why you need a human" (or --clear to lower it)'); process.exit(1); }
    out(await req('POST', '/api/xell/self/tend', { reason: reason || null, clear }));
    break;
  }
  case 'ship': {
    const reason = flag('reason'); const targets = multi('targets');
    if (!reason) { console.error('ship needs --reason "what you are shipping"'); process.exit(1); }
    out(await req('POST', '/api/xell/self/ship', { reason, ...(targets ? { targets } : {}) }));
    break;
  }
  case 'hint-land': case 'hint-ship': {
    // Surface the land?/ship? prompt for a human WITHOUT calling the gated land/ship. Use this
    // whenever you are not 100% certain the job is done — leave the decision to the human's button.
    const kind = cmd === 'hint-land' ? 'land' : 'ship';
    const clear = rest.includes('--clear');
    out(await req('POST', `/api/xell/self/hint-${kind}`, { reason: flag('reason') || null, clear }));
    break;
  }
  case 'prod': {
    const reason = flag('reason');
    if (!reason) { console.error('prod needs --reason "why you need the prod database"'); process.exit(1); }
    out(await req('POST', '/api/xell/self/prod-request', { reason }));
    break;
  }
  case 'done': {
    const summary = flag('summary');
    out(await req('POST', '/api/xell/self/done', { summary }));
    break;
  }
  case 'help': case undefined: usage(); break;
  default: console.error(`unknown command: ${cmd}`); usage();
}
