# Shell scripts are executed by Git bash — a CRLF checkout breaks every one of them
# ("\r: command not found"), and autocrlf=true on Windows does exactly that to fresh
# checkouts, including every xell worktree. Pin them to LF everywhere.
*.sh text eol=lf

# The `zee` CLI (and every .mjs the queenzee runs) has a `#!/usr/bin/env node` shebang. A CRLF
# checkout turns that into `#!/usr/bin/env node\r`, so the kernel looks for an interpreter literally
# named "node\r" and the script dies with `node\r: No such file or directory` — a cxell zee then
# can't run `zee land` bare and has to work around it with `node /usr/local/bin/zee`. These are
# scripts, executed by their shebang, and must be LF on every platform including a Windows checkout.
scripts/zee text eol=lf
docker/zeehive/zee text eol=lf
*.mjs text eol=lf
