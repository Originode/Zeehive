# ── ZEEHIVE / queenzee configuration ──────────────────────────────────────
# Postgres meta database (the single source of truth)
# (docker-compose.yml maps the db to :5445; Mark's real one is the NAS: 10.1.0.18:5445)
DATABASE_URL=postgres://zeehive:zeehive@localhost:5445/zeehive

# Node API + queenzee
PORT=4700
# Where the queenzee API is reachable by hooks & the /xell skill (localhost)
ZEEHIVE_API=http://localhost:4700

# Claude Code home (where sessions/, projects/, settings.json live)
CLAUDE_HOME=C:\Users\Mark\.claude

# Reference project (OmniBiz) — used by the seed + provisioning
OMNIBIZ_ROOT=D:\Repos\OmniBiz\omnibiz
SPINOFF_DOCKER_CONTEXT=ugreen-nas
DEV_HOST_IP=10.1.0.18

# Pool
POOL_TARGET_READY=3

# ── OPERATIONAL MODE FLAGS — put the real values HERE, not only in your shell ────
# dotenv loads these at boot, so a bare `npm run server` (a self-ship restart, a crash
# relaunch, a curious terminal) can NEVER silently regress the queenzee to simulate.
# On 2026-07-17 exactly that happened: a restart without PROVISION_MODE=real left four
# "ready" xells as DB rows with no worktrees. CLI env still overrides when set.
#PROVISION_MODE=real
#BUILD_MODE=real
#SHIP_MODE=real
#PROVISION_APP_TIER=false

# Queenzee loop cadence (ms)
POLLER_INTERVAL_MS=4000
POOL_INTERVAL_MS=15000
